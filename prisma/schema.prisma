generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  password      String?
  bio           String    @default("")
  avatar        String    @default("")
  authProvider  String    @default("email") @map("auth_provider")
  isPrivate     Boolean   @default(false) @map("is_private")
  termsAcceptedAt DateTime? @map("terms_accepted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  ratings        Rating[]
  reviews        Review[]
  libraryEntries LibraryEntry[]
  following      Follow[]       @relation("follower")
  followers      Follow[]       @relation("followed")

  @@map("users")
}

model Account {
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Item {
  id          Int      @id @default(autoincrement())
  title       String
  type        String
  genre       String[]
  vibes       String[]
  year        Int
  cover       String
  description String
  people      Json
  awards      Json
  platforms   Json
  ext         Json
  totalEp     Int      @default(0) @map("total_ep")

  isUpcoming  Boolean  @default(false) @map("is_upcoming")
  releaseDate String?  @map("release_date")
  hypeScore   Int?     @map("hype_score")
  wantCount   Int?     @map("want_count")

  wikidataId      String?  @map("wikidata_id")
  popularityScore Float    @default(0) @map("popularity_score")
  voteCount       Int      @default(0) @map("vote_count")

  parentItemId    Int?     @map("parent_item_id")
  itemSubtype     String?  @map("item_subtype") // 'base', 'dlc', 'expansion', 'season_pass', or null

  createdAt       DateTime @default(now()) @map("created_at")

  parentItem     Item?    @relation("ItemDLC", fields: [parentItemId], references: [id])
  dlcs           Item[]   @relation("ItemDLC")

  ratings        Rating[]
  reviews        Review[]
  libraryEntries LibraryEntry[]
  franchiseItems FranchiseItem[]
  externalScores ExternalScore[]

  @@index([type])
  @@index([year])
  @@index([createdAt])
  @@index([isUpcoming])
  @@index([type, year])
  @@index([type, isUpcoming])
  @@index([parentItemId])
  @@map("items")
}

model ExternalScore {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  source    String   // e.g. "imdb", "rt_critics", "rt_audience", "metacritic", "mal", "anilist", "goodreads", "steam", "pitchfork", "ign", "spotify_popularity"
  score     Float    // the numeric value
  maxScore  Float    @map("max_score") // e.g. 10 for IMDb, 100 for RT/Meta, 5 for Goodreads
  scoreType String   @default("community") @map("score_type") // "critics", "community", "platform"
  label     String   @default("") // display label e.g. "Overwhelmingly Positive"
  updatedAt DateTime @default(now()) @map("updated_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, source])
  @@index([itemId])
  @@map("external_scores")
}

model Franchise {
  id               Int        @id @default(autoincrement())
  name             String
  icon             String     @default("")
  description      String     @default("")
  cover            String     @default("")
  autoGenerated    Boolean    @default(false) @map("auto_generated")
  confidenceTier   Int        @default(1) @map("confidence_tier")
  parentFranchiseId Int?      @map("parent_franchise_id")
  wikidataId       String?    @map("wikidata_id")
  createdAt        DateTime   @default(now()) @map("created_at")

  parentFranchise  Franchise?  @relation("FranchiseHierarchy", fields: [parentFranchiseId], references: [id])
  childFranchises  Franchise[] @relation("FranchiseHierarchy")
  items            FranchiseItem[]

  @@map("franchises")
}

model FranchiseItem {
  franchiseId Int    @map("franchise_id")
  itemId      Int    @map("item_id")
  addedBy     String @default("auto") @map("added_by")

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([franchiseId, itemId])
  @@index([itemId])
  @@index([franchiseId])
  @@map("franchise_items")
}

model SuggestedConnection {
  id             Int      @id @default(autoincrement())
  itemId1        Int      @map("item_id_1")
  itemId2        Int      @map("item_id_2")
  reason         String
  confidenceTier Int      @map("confidence_tier")
  reviewed       Boolean  @default(false)
  approved       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("suggested_connections")
}

model Rating {
  userId       String   @map("user_id")
  itemId       Int      @map("item_id")
  score        Int
  recommendTag String?  @map("recommend_tag")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([itemId])
  @@index([userId])
  @@map("ratings")
}

model Review {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  itemId       Int      @map("item_id")
  text         String
  helpfulCount Int      @default(0) @map("helpful_count")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([userId])
  @@map("reviews")
}

model LibraryEntry {
  userId          String    @map("user_id")
  itemId          Int       @map("item_id")
  status          String
  progressCurrent Int       @default(0) @map("progress_current")
  progressTotal   Int       @default(0) @map("progress_total")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([userId])
  @@index([userId, status])
  @@map("library_entries")
}

model Follow {
  followerId String   @map("follower_id")
  followedId String   @map("followed_id")
  createdAt  DateTime @default(now()) @map("created_at")

  follower User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("followed", fields: [followedId], references: [id], onDelete: Cascade)

  @@id([followerId, followedId])
  @@map("follows")
}
