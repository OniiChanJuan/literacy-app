generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

/// Mirrors Supabase Auth's auth.users row. The id column is the same
/// UUID as auth.users.id — a database trigger keeps this table in sync
/// on insert. Password hashing, email verification, OAuth account
/// linking, and session management all live in auth.users and are not
/// duplicated here.
model User {
  id              String    @id @db.Uuid
  email           String    @unique
  username        String?   @unique
  name            String?
  image           String?
  bio             String    @default("")
  avatar          String    @default("")
  authProvider    String    @default("email") @map("auth_provider")
  memberNumber    Int?      @unique @map("member_number")
  isPrivate       Boolean   @default(false) @map("is_private")
  termsAcceptedAt DateTime? @map("terms_accepted_at")
  tasteProfile    Json?     @map("taste_profile")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  ratings         Rating[]
  reviews         Review[]
  libraryEntries  LibraryEntry[]
  following       Follow[]       @relation("follower")
  followers       Follow[]       @relation("followed")
  settings        UserSettings?
  helpfulVotes    ReviewHelpfulVote[]
  implicitSignals ImplicitSignal[]
  dismissedItems  DismissedItem[]
  notifications   Notification[]
  reports         Report[]       @relation("reporter")
  imports         Import[]
  tagSuggestions  UserTagSuggestion[]
  crossConnectionVotes CrossConnectionVote[]
  connectionRecVotes   ConnectionRecVote[]
  connectionDismissals ConnectionDismissal[]
  connectionEvents     ConnectionEvent[]
  connectionCredits    ConnectionCredit[]
  franchiseRatings     FranchiseRating[]
  franchiseFollows     FranchiseFollow[]

  @@map("users")
}

/// Public-safe projection of users. SQL view defined in
/// scripts/migrate-create-public-user-profiles-view.ts. Granted
/// SELECT to anon and authenticated; not insertable/updatable from
/// the app side. Use this model anywhere the app reads other users'
/// public profile data so that the read surface stays narrow.
view PublicUserProfile {
  id           String   @unique @db.Uuid
  name         String?
  username     String?
  bio          String
  avatar       String
  image        String?
  memberNumber Int?     @map("member_number")
  createdAt    DateTime @map("created_at")
  isPrivate    Boolean  @map("is_private")

  @@map("public_user_profiles")
}

model UserSettings {
  userId                String  @id @db.Uuid @map("user_id")
  showRatingsPublicly   Boolean @default(true) @map("show_ratings_publicly")
  showLibraryPublicly   Boolean @default(true) @map("show_library_publicly")
  showActivityPublicly  Boolean @default(true) @map("show_activity_publicly")
  theme                 String  @default("dark")
  defaultMediaType      String  @default("all") @map("default_media_type")
  showMatureContent     Boolean @default(true) @map("show_mature_content")
  emailNewFollower      Boolean @default(true) @map("email_new_follower")
  emailReviewLiked      Boolean @default(true) @map("email_review_liked")
  emailFranchiseRelease Boolean @default(true) @map("email_franchise_release")
  emailWeeklyDigest     Boolean @default(true) @map("email_weekly_digest")
  favoriteMediaTypes    Json    @default("[]") @map("favorite_media_types")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Item {
  id          Int      @id @default(autoincrement())
  title       String
  type        String
  genre       String[]
  vibes       String[]
  year        Int
  cover       String
  description String
  people      Json
  awards      Json
  platforms   Json
  ext         Json
  totalEp     Int      @default(0) @map("total_ep")

  isUpcoming  Boolean  @default(false) @map("is_upcoming")
  releaseDate String?  @map("release_date")
  hypeScore   Int?     @map("hype_score")
  wantCount   Int?     @map("want_count")

  wikidataId      String?  @map("wikidata_id")
  tmdbId          Int?     @map("tmdb_id")
  igdbId          Int?     @map("igdb_id")
  malId           Int?     @map("mal_id")
  spotifyId       String?  @map("spotify_id")
  googleBooksId   String?  @map("google_books_id")
  isbn            String?  @map("isbn")
  comicVineId     Int?     @map("comic_vine_id")
  steamAppId      Int?     @map("steam_app_id")
  slug            String?  @map("slug")
  popularityScore Float    @default(0) @map("popularity_score")
  voteCount       Int      @default(0) @map("vote_count")
  lastSyncedAt    DateTime? @map("last_synced_at")

  parentItemId    Int?     @map("parent_item_id")
  itemSubtype     String?  @map("item_subtype")
  primaryColor    String?  @map("primary_color")
  secondaryColor  String?  @map("secondary_color")
  itemDimensions  Json?    @map("item_dimensions")
  platformLinks   Json?    @map("platform_links")
  watchProviders  Json?    @map("watch_providers")
  itemTags        Json?    @map("item_tags")

  createdAt       DateTime @default(now()) @map("created_at")

  parentItem     Item?    @relation("ItemDLC", fields: [parentItemId], references: [id], onDelete: SetNull)
  dlcs           Item[]   @relation("ItemDLC")

  ratings        Rating[]
  reviews        Review[]
  libraryEntries LibraryEntry[]
  franchiseItems FranchiseItem[]
  externalScores ExternalScore[]
  implicitSignals ImplicitSignal[]
  dismissedItems  DismissedItem[]
  tagSuggestions UserTagSuggestion[]
  crossConnections CrossConnection[]
  connectionEvents ConnectionEvent[]
  connectionCredits ConnectionCredit[]
  connectionRecs   ConnectionRec[]
  pendingTitleResolutions ConnectionPendingTitle[]

  @@index([type])
  @@index([year])
  @@index([createdAt])
  @@index([isUpcoming])
  @@index([type, year])
  @@index([type, isUpcoming])
  @@index([parentItemId])
  @@index([steamAppId])
  @@index([type, slug])
  @@map("items")
}

model ExternalScore {
  id        Int      @id @default(autoincrement())
  itemId    Int      @map("item_id")
  source    String   // e.g. "imdb", "rt_critics", "rt_audience", "metacritic", "mal", "anilist", "goodreads", "steam", "pitchfork", "ign", "spotify_popularity"
  score     Float    // the numeric value
  maxScore  Float    @map("max_score") // e.g. 10 for IMDb, 100 for RT/Meta, 5 for Goodreads
  scoreType String   @default("community") @map("score_type") // "critics", "community", "platform"
  label     String   @default("") // display label e.g. "Overwhelmingly Positive"
  updatedAt DateTime @default(now()) @map("updated_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, source])
  @@index([itemId])
  @@map("external_scores")
}

model Franchise {
  id               Int        @id @default(autoincrement())
  name             String
  icon             String     @default("")
  description      String     @default("")
  cover            String     @default("")
  autoGenerated    Boolean    @default(false) @map("auto_generated")
  confidenceTier   Int        @default(1) @map("confidence_tier")
  parentFranchiseId Int?      @map("parent_franchise_id")
  wikidataId       String?    @map("wikidata_id")
  createdAt        DateTime   @default(now()) @map("created_at")

  parentFranchise  Franchise?  @relation("FranchiseHierarchy", fields: [parentFranchiseId], references: [id], onDelete: SetNull)
  childFranchises  Franchise[] @relation("FranchiseHierarchy")
  items            FranchiseItem[]
  follows          FranchiseFollow[]
  ratings          FranchiseRating[]

  @@map("franchises")
}

model FranchiseRating {
  userId      String @db.Uuid @map("user_id")
  franchiseId Int      @map("franchise_id")
  rating      Int      // 1-5
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, franchiseId])
  @@index([franchiseId])
  @@index([userId])
  @@map("franchise_ratings")
}

model FranchiseFollow {
  userId      String @db.Uuid @map("user_id")
  franchiseId Int      @map("franchise_id")
  createdAt   DateTime @default(now()) @map("created_at")

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, franchiseId])
  @@index([userId])
  @@index([franchiseId])
  @@map("franchise_follows")
}

model FranchiseItem {
  franchiseId Int    @map("franchise_id")
  itemId      Int    @map("item_id")
  addedBy     String @default("auto") @map("added_by")

  franchise Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([franchiseId, itemId])
  @@index([itemId])
  @@index([franchiseId])
  @@map("franchise_items")
}

model SuggestedConnection {
  id             Int      @id @default(autoincrement())
  itemId1        Int      @map("item_id_1")
  itemId2        Int      @map("item_id_2")
  reason         String
  confidenceTier Int      @map("confidence_tier")
  reviewed       Boolean  @default(false)
  approved       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("suggested_connections")
}

model Rating {
  userId       String @db.Uuid @map("user_id")
  itemId       Int      @map("item_id")
  score        Int
  recommendTag String?  @map("recommend_tag")
  importSource String?  @map("import_source")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([itemId])
  @@index([userId])
  @@map("ratings")
}

model Review {
  id               Int      @id @default(autoincrement())
  userId           String @db.Uuid @map("user_id")
  itemId           Int      @map("item_id")
  parentId         Int?     @map("parent_id")
  depth            Int      @default(0)
  text             String
  containsSpoilers Boolean  @default(false) @map("contains_spoilers")
  helpfulCount     Int      @default(0) @map("helpful_count")
  voteScore        Int      @default(0) @map("vote_score")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  item         Item               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  parent       Review?            @relation("ReviewReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Review[]           @relation("ReviewReplies")
  helpfulVotes ReviewHelpfulVote[]
  reports      Report[]

  // No @@unique([userId, itemId]) — replies allow multiple rows per user+item
  @@index([itemId])
  @@index([userId])
  @@index([parentId])
  @@index([itemId, voteScore(sort: Desc), createdAt(sort: Desc)])
  @@index([itemId, createdAt])
  @@map("reviews")
}

model ReviewHelpfulVote {
  userId    String @db.Uuid @map("user_id")
  reviewId  Int      @map("review_id")
  voteType  String   @default("up") @map("vote_type")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
  @@index([reviewId])
  @@map("review_helpful_votes")
}

model LibraryEntry {
  userId          String @db.Uuid @map("user_id")
  itemId          Int       @map("item_id")
  status          String
  progressCurrent Int       @default(0) @map("progress_current")
  progressTotal   Int       @default(0) @map("progress_total")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([userId])
  @@index([userId, status])
  @@map("library_entries")
}

model Follow {
  followerId String @db.Uuid @map("follower_id")
  followedId String @db.Uuid @map("followed_id")
  createdAt  DateTime @default(now()) @map("created_at")

  follower User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followed User @relation("followed", fields: [followedId], references: [id], onDelete: Cascade)

  @@id([followerId, followedId])
  @@map("follows")
}

model ImplicitSignal {
  id         Int      @id @default(autoincrement())
  userId     String @db.Uuid @map("user_id")
  itemId     Int      @map("item_id")
  signalType String   @map("signal_type") // page_view, want_to_add, franchise_view, genre_filter
  value      Float    @default(1)
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId, signalType])
  @@index([userId, itemId])
  @@map("implicit_signals")
}

model DismissedItem {
  userId    String @db.Uuid @map("user_id")
  itemId    Int      @map("item_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@map("dismissed_items")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String @db.Uuid @map("user_id")
  message   String
  type      String   // content_removed, account_warning, system
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

model DmcaNotice {
  id              Int      @id @default(autoincrement())
  reporterName    String   @map("reporter_name")
  reporterEmail   String   @map("reporter_email")
  copyrightedWork String   @map("copyrighted_work")
  infringingUrl   String   @map("infringing_url")
  statement       String
  status          String   @default("pending") // pending, reviewed, actioned, rejected
  createdAt       DateTime @default(now()) @map("created_at")
  reviewedAt      DateTime? @map("reviewed_at")

  @@map("dmca_notices")
}

model Report {
  id             Int      @id @default(autoincrement())
  reporterUserId String @db.Uuid @map("reporter_user_id")
  reviewId       Int      @map("review_id")
  reason         String   // spam, harassment, hate_speech, spoilers, other
  details        String   @default("")
  status         String   @default("pending") // pending, reviewed, dismissed, actioned
  createdAt      DateTime @default(now()) @map("created_at")

  reporter User   @relation("reporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([status])
  @@map("reports")
}

model Tag {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  displayName String   @map("display_name")
  category    String   // theme, setting, character, tone, narrative, pacing, music, game, anime, tv, book, podcast, comic
  appliesTo   String[] @map("applies_to") // empty = universal
  createdAt   DateTime @default(now()) @map("created_at")

  suggestions UserTagSuggestion[]

  @@index([category])
  @@index([slug])
  @@map("tags")
}

model UserTagSuggestion {
  id        Int      @id @default(autoincrement())
  userId    String @db.Uuid @map("user_id")
  itemId    Int      @map("item_id")
  tagSlug   String   @map("tag_slug")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagSlug], references: [slug], onDelete: Cascade)

  @@unique([userId, itemId, tagSlug])
  @@index([itemId, tagSlug])
  @@index([userId])
  @@map("user_tag_suggestions")
}

model PlatformClick {
  id         Int      @id @default(autoincrement())
  itemId     Int      @map("item_id")
  platform   String   // e.g. "netflix", "steam", "spotify"
  userId     String? @db.Uuid @map("user_id")
  referrer   String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([itemId])
  @@index([platform])
  @@index([createdAt])
  @@map("platform_clicks")
}

model Import {
  id             Int      @id @default(autoincrement())
  userId         String @db.Uuid @map("user_id")
  source         String   // letterboxd, goodreads, myanimelist, steam, spotify
  status         String   @default("pending") // pending, processing, completed, failed
  totalItems     Int      @default(0) @map("total_items")
  importedItems  Int      @default(0) @map("imported_items")
  skippedItems   Int      @default(0) @map("skipped_items")
  failedItems    Int      @default(0) @map("failed_items")
  duplicateItems Int      @default(0) @map("duplicate_items")
  details        Json?    // extra info: filename, username, errors array, etc.
  startedAt      DateTime @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, source])
  @@map("imports")
}


/// Editorially curated cross-media recommendations.
/// recommendedItems is a JSONB array of { item_id, title, type } objects,
/// because a connection can point at 1-3 items of any media type.
/// Curated editorial strength — PROTECTED. Set only from the authored corpus
/// grade (or implicitly `medium` for un-authored legacy rows). NEVER written by
/// votes, dismiss, click-credits, or the decay cron. This (per-rec, on
/// ConnectionRec) is the read-layer ordering input.
enum CuratedStrength {
  tight
  medium
  attenuated

  @@map("curated_strength")
}

/// THE CARD = one anchor (source Item) × one cluster. The unit the user sees,
/// votes on, and dismisses. Evolution of the original flat row: source_item_id
/// stays (so votes/dismissals/events/credits keep their connection_id FK), plus
/// a cluster link, normalized recs (ConnectionRec), and an INERT community lane.
model CrossConnection {
  id               Int      @id @default(autoincrement())
  sourceItemId     Int      @map("source_item_id")
  clusterId        Int?     @map("cluster_id")            // null only for un-clustered legacy rows
  recommendedItems Json     @map("recommended_items")     // legacy JSON recs (superseded by ConnectionRec)
  reason           String                                 // = cluster blurb, or a per-anchor override
  themeTags        String[] @default([]) @map("theme_tags")
  position         Int      @default(0)                   // cluster order under the anchor (authoring)
  createdBy        String   @default("editorial") @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  // ── COMMUNITY LANE (inert; recorded, not acted on pre-50-users) ──
  // The ONLY mutable signal field; the four behavioral mutators write HERE.
  // Default 0.0 = neutral. Ignored by the read layer until vote-weighting is
  // deliberately enabled. NEVER blended into a curated column.
  communityAdjustment Float @default(0.0) @map("community_adjustment")

  // NOTE: quality_score is RETAINED (default 1.0) but DEPRECATED — kept only to
  // keep the cutover reversible. It is never read into a curated grade. Dropped
  // in a later step once the read layer is fully repointed.
  qualityScore     Float    @default(1.0) @map("quality_score")

  sourceItem  Item                   @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  cluster     ConnectionCluster?     @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  recs        ConnectionRec[]
  votes       CrossConnectionVote[]
  dismissals  ConnectionDismissal[]
  events      ConnectionEvent[]
  credits     ConnectionCredit[]

  @@unique([sourceItemId, clusterId])    // one card per (anchor, cluster); import idempotency
  @@index([sourceItemId])
  @@index([clusterId])
  @@index([qualityScore])
  @@map("cross_connections")
}

/// Canonical cluster (225). Authored ONCE; reused by many anchors across types.
/// Identity = the consolidated "Canonical Clusters" sheet.
model ConnectionCluster {
  id          Int      @id @default(autoincrement())
  slug        String   @unique                  // stable key for idempotent import + authoring tool
  label       String                             // cluster "reason" name
  blurb       String                             // user-facing sentence shown on card expand
  spans       String[] @default([])              // media types it spans (denormalized for the workhorse query)
  isCanonical Boolean  @default(true) @map("is_canonical")  // false = single-anchor unique cluster
  mergedFrom  String[] @default([]) @map("merged_from")     // provenance: original cluster names folded in
  createdBy   String   @default("import") @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  cards CrossConnection[]

  @@map("connection_clusters")
}

/// A single graded recommendation inside a card. curated_strength lives HERE
/// (per-rec), protected. Exactly one of rec_item_id / pending_title_id is set.
model ConnectionRec {
  id               Int             @id @default(autoincrement())
  connectionId     Int             @map("connection_id")
  recItemId        Int?            @map("rec_item_id")
  pendingTitleId   Int?            @map("pending_title_id")
  curatedStrength  CuratedStrength @map("curated_strength")        // PROTECTED enum
  sharedThreads    String[]        @default([]) @map("shared_threads")  // connection-logic tags
  recMediaAuthored String?         @map("rec_media_authored")      // media as authored (cross-media display)
  whatItIs         String?         @map("what_it_is")              // editorial descriptor
  position         Int             @default(0)
  createdBy        String          @default("import") @map("created_by")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")

  connection   CrossConnection         @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  recItem      Item?                   @relation(fields: [recItemId], references: [id], onDelete: SetNull)
  pendingTitle ConnectionPendingTitle? @relation(fields: [pendingTitleId], references: [id], onDelete: SetNull)
  votes        ConnectionRecVote[]

  @@unique([connectionId, recItemId])     // dedupe a resolved rec within a card
  @@index([connectionId])
  @@index([recItemId])
  @@index([pendingTitleId])
  @@index([curatedStrength])
  @@map("connection_recs")
}

/// Connections (or anchors) referencing a title not yet in the catalog.
/// Mistborn + Outer Wilds (recon §2B) land here unless Step 2 ingests them first.
model ConnectionPendingTitle {
  id             Int      @id @default(autoincrement())
  titleAuthored  String   @map("title_authored")
  mediaAuthored  String   @map("media_authored")
  whatItIs       String?  @map("what_it_is")
  normalizedKey  String   @map("normalized_key")    // reconciliation-matcher key for later auto-resolve
  reason         String   @default("not_in_catalog")  // 'not_in_catalog' | 'ambiguous' | 'non_ingestable'
  resolvedItemId Int?     @map("resolved_item_id")   // set when ingested; backfill links recs → real item
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  recs         ConnectionRec[]
  resolvedItem Item?  @relation(fields: [resolvedItemId], references: [id], onDelete: SetNull)

  @@unique([normalizedKey, mediaAuthored])
  @@index([resolvedItemId])
  @@map("connection_pending_titles")
}

/// One row per (user, connection) that the user dismissed from the
/// Cross your shelf section. PK enforces idempotency so the −0.15
/// dismiss delta only applies once per pair. Hidden connections are
/// excluded from /api/cross-connections GET in code (Prisma bypasses
/// RLS via the superuser pooler).
model ConnectionDismissal {
  userId       String   @db.Uuid @map("user_id")
  connectionId Int      @map("connection_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  connection CrossConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, connectionId])
  @@index([connectionId])
  @@map("connection_dismissals")
}

/// Append-only log of user-facing connection events used for strict
/// attribution of downstream signals. event_type:
///   - "impression"  → card rendered for this user (batched per page)
///   - "cover_click" → user clicked a recommended-item cover inside
///                     the card (item_id identifies which rec)
/// Pruned periodically (rows older than 30 days carry no attribution
/// value — both windows are <= 30d). See src/lib/connection-credit.ts.
model ConnectionEvent {
  id           BigInt   @id @default(autoincrement())
  userId       String   @db.Uuid @map("user_id")
  connectionId Int      @map("connection_id")
  eventType    String   @map("event_type") // 'impression' | 'cover_click'
  itemId       Int?     @map("item_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection CrossConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  item       Item?           @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId, connectionId, eventType, createdAt(sort: Desc)])
  @@index([connectionId, eventType, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("connection_events")
}

/// Per-(user, connection, item, signal_class) credit ledger. Records
/// the highest tier of positive credit applied + the cumulative delta
/// written to cross_connections.quality_score. Updated in-place when
/// a higher tier fires; tier 0 + a negative delta_applied represents
/// the "rating <= 2 / skip" negative-credit case. See SCORE_DELTAS
/// in src/lib/connection-score.ts for tier definitions.
model ConnectionCredit {
  userId       String   @db.Uuid @map("user_id")
  connectionId Int      @map("connection_id")
  itemId       Int      @map("item_id")
  signalClass  String   @map("signal_class") // currently only 'downstream'
  tier         Int
  deltaApplied Float    @map("delta_applied")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection CrossConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, connectionId, itemId, signalClass])
  @@index([connectionId])
  @@map("connection_credits")
}

/// One vote per user per connection. +1 upvote, -1 downvote.
/// quality_score on the parent is adjusted in the vote route.
model CrossConnectionVote {
  userId       String   @db.Uuid @map("user_id")
  connectionId Int      @map("connection_id")
  vote         Int // +1 or -1
  createdAt    DateTime @default(now()) @map("created_at")

  connection CrossConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, connectionId])
  @@index([connectionId])
  @@map("cross_connection_votes")
}

/// One vote per user per individual recommendation (a connection_recs row).
/// Finer-grained than CrossConnectionVote (which is per-card). +1/-1. Mobile's
/// per-rec thumbs write here; desktop's per-connection thumbs keep using
/// cross_connection_votes — separate clean lanes. CAPTURE-ONLY: recorded for
/// future Stage-3 use, NEVER mutates curated_strength (the pre-50-user decoupling).
model ConnectionRecVote {
  userId          String   @db.Uuid @map("user_id")
  connectionRecId Int      @map("connection_rec_id")
  vote            Int // +1 or -1
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  rec  ConnectionRec @relation(fields: [connectionRecId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, connectionRecId])
  @@index([connectionRecId])
  @@map("connection_rec_votes")
}
